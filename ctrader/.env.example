# =====================================
# iZFx.Trade – Environment Configuration
# =====================================
# Copy file này thành .env và điền thông tin của bạn
# cp .env.example .env

# ── cTrader Open API ──────────────────
CTRADER_CLIENT_ID=12739_your_client_id_here
CTRADER_SECRET=your_secret_here
CTRADER_HOST=openapi.ctrader.com
CTRADER_PORT=5035

# ── Telegram Bot ─────────────────────
TELEGRAM_BOT_TOKEN=6972526694:your_bot_token_here
# Admin IDs (phân cách bằng dấu phẩy) — ai được phép dùng lệnh
TELEGRAM_ADMIN_IDS=975318323
# Channel hoặc Group nhận thông báo trade (dùng @username hoặc -100xxxxxxx)
TELEGRAM_NOTIFY_CHAT_ID=@TradeKiemGold

# ── REST API ──────────────────────────
API_KEY=your_secure_api_key_here
API_PORT=7381

# ── Database ──────────────────────────
DATABASE_URL=sqlite://iztrade.db

# ── Logging ───────────────────────────
# Levels: error, warn, info, debug, trace
LOG_LEVEL=info

# ── Mode ─────────────────────────────
# mock = giả lập cTrader (test Telegram + API)
# live = kết nối cTrader thật
CTRADER_MODE=mock
